{
  "manifest_version": 3,
  "name": "AI Fraud Shield - Scam Detector",
  "version": "1.0.0",
  "description": "Protect yourself from SMS, email, and web scams in Kenya",
  "permissions": [
    "activeTab",
    "storage",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*/*",
    "http://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Fraud Shield",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}